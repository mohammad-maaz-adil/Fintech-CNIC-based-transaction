# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup batch script, version 3.3.2
#
# Required ENV vars:
# ------------------
#   JAVA_HOME - location of a JDK home dir
#
# Optional ENV vars
# -----------------
#   MAVEN_OPTS - parameters passed to the Java VM when running Maven
#     e.g. to debug Maven itself, use
#       set MAVEN_OPTS=-Xdebug -Xrunjdwp:transport=dt_socket,server=y,suspend=y,address=8000
#   MAVEN_SKIP_RC - flag to disable loading of mavenrc files
# ----------------------------------------------------------------------------

if [ -z "$MAVEN_SKIP_RC" ] ; then
  if [ -f /usr/local/etc/mavenrc ] ; then
    . /usr/local/etc/mavenrc
  fi
  if [ -f /etc/mavenrc ] ; then
    . /etc/mavenrc
  fi
  if [ -f "$HOME/.mavenrc" ] ; then
    . "$HOME/.mavenrc"
  fi
fi

# OS specific support.  $var _must_ be set to either true or false.
cygwin=false;
darwin=false;
mingw=false
case "`uname`" in
  CYGWIN*) cygwin=true ;;
  MINGW*) mingw=true;;
  Darwin*) darwin=true ;;
esac

## -z "$JAVA_HOME" is platform independent
if [ -z "$JAVA_HOME" ] ; then
  if [ -r /etc/gentoo-release ] ; then
    JAVA_HOME=`java-config --jre-home`
  fi
fi

# For Cygwin, ensure paths are in UNIX format before anything is touched
if $cygwin ; then
  [ -n "$JAVA_HOME" ] &&
    JAVA_HOME=`cygpath --unix "$JAVA_HOME"`
  [ -n "$CLASSPATH" ] &&
    CLASSPATH=`cygpath --path --unix "$CLASSPATH"`
fi

# For Mingw, ensure paths are in UNIX format before anything is touched
if $mingw ; then
  [ -n "$JAVA_HOME" ] &&
    JAVA_HOME="`(cd "$JAVA_HOME"; pwd)`"
fi

if [ -z "$JAVA_HOME" ] ; then
  javaExecutable="`which javaw`"
  if [ -z "$javaExecutable" ] || [ "`ls -1 /proc/[0-9]*/fd/2>/dev/null | wc -l`" = "0" ]; then
    javaExecutable="`which java`"
  fi
  if [ -n "$javaExecutable" ] && ! [ "`expr \"$javaExecutable\" : '\([a-zA-Z]:.*\)'`" = "" ]; then
    # path contains :, so it's Windows style
    javaExecutable="`cygpath $javaExecutable`"
  fi
  if [ -n "$javaExecutable" ]; then
    javaHome="`dirname \"$javaExecutable\"`"
    javaExecutable="`cd \"$javaHome\" && pwd -P`/javaw"
    if [ ! -x "$javaExecutable" ]; then
      javaExecutable="`cd \"$javaHome\" && pwd -P`/java"
    fi
  fi
fi

if [ -z "$JAVA_HOME" ] && [ -n "$javaHome" ] ; then
  JAVA_HOME="$javaHome"
fi

# For Cygwin, switch paths to Windows format before running java
if $cygwin; then
  [ -n "$JAVA_HOME" ] &&
    JAVA_HOME=`cygpath --path --windows "$JAVA_HOME"`
  [ -n "$CLASSPATH" ] &&
    CLASSPATH=`cygpath --path --windows "$CLASSPATH"`
fi

WRAPPER_LAUNCHER=org.apache.maven.wrapper.MavenWrapperMain

WRAPPER_URL="$MVNW_REPOURL"
if [ -z "$WRAPPER_URL" ]; then
  WRAPPER_URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.3.2/maven-wrapper-3.3.2.jar"
fi

MAVEN_PROJECTBASEDIR=${MAVEN_BASEDIR:-"$( cd -P "$(dirname "$0")" && pwd )"}
MAVEN_OPTS="$MAVEN_OPTS -Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR"

wrapperJarFile="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
if [ -r "$wrapperJarFile" ]; then
    exec "$JAVA_HOME/bin/java" $MAVEN_OPTS $JVMARGS \
      -classpath "$wrapperJarFile" \
      "-Dmaven.multiModuleProjectDirectory=${MAVEN_PROJECTBASEDIR}" \
      ${WRAPPER_LAUNCHER} "$@"
else
    # If wrapper jar is not available, download Maven directly
    if command -v curl > /dev/null; then
      exec curl -fsSL "https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.6/apache-maven-3.9.6-bin.tar.gz" | tar xz -C /tmp && exec /tmp/apache-maven-3.9.6/bin/mvn "$@"
    elif command -v wget > /dev/null; then
      exec wget -qO- "https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.6/apache-maven-3.9.6-bin.tar.gz" | tar xz -C /tmp && exec /tmp/apache-maven-3.9.6/bin/mvn "$@"
    else
      exec mvn "$@"
    fi
fi
